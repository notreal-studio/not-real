---
import Base from "../layouts/Base.astro";
import { languages, defaultLang, langName, useTranslations, localePath, type Lang } from "../i18n/utils";

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL;


const work = [1, 2, 3, 4];
---
<Base lang={lang}>
  {/* LOADER */}
  <div id="loader">
    <div class="ln serif">Not <b>Real</b></div>
    <div class="lc"><span id="lcount">0</span> — {t("loader.loading")}</div>
    <div class="lbar" id="lbar"></div>
  </div>

  {/* NAV */}
  <header>
    <div class="wrap nav">
      <a class="brand" href="#top"><span class="dot"></span>Not Real</a>
      <div class="nav-actions">
        <div class="header-lang">
          {languages.map((l) => (
            <a href={localePath(l, base)} class={l === lang ? "is-active" : ""}>{langName[l]}</a>
          ))}
        </div>
        <button class="theme-toggle" id="themeToggle" aria-label={t("theme.toggle")}>
          <svg class="i-sun" viewBox="0 0 24 24"><circle cx="12" cy="12" r="4.2"/><path d="M12 2.5v3M12 18.5v3M4.2 4.2l2.1 2.1M17.7 17.7l2.1 2.1M2.5 12h3M18.5 12h3M4.2 19.8l2.1-2.1M17.7 6.3l2.1-2.1" stroke-linecap="round"/></svg>
          <svg class="i-moon" viewBox="0 0 24 24"><path d="M20 14.5A8.5 8.5 0 0 1 9.5 4 8.5 8.5 0 1 0 20 14.5Z" stroke-linejoin="round"/></svg>
        </button>
        <button class="menu-btn" id="menuOpen"><span>{t("nav.menu")}</span><span class="bars"><i></i><i></i></span></button>
      </div>
    </div>
  </header>

  {/* OVERLAY MENU */}
  <nav id="menu" aria-hidden="true">
    <div class="menu-inner">

      {/* TOP BAR */}
      <div class="menu-top">
        <a class="menu-nr-logo" href="#top" onclick="document.getElementById('menuClose').click()">
          <svg viewBox="0 0 100 100" width="52" height="52">
            <rect width="100" height="100" fill="none"/>
            <text x="50" y="71" text-anchor="middle" font-family="'Instrument Serif',Georgia,serif" font-size="56" font-weight="400" letter-spacing="3" fill="currentColor">NR</text>
          </svg>
        </a>
        <div class="menu-top-right">
          <div class="menu-lang">
            {languages.map((l) => (
              <a href={localePath(l, base)} class={l === lang ? "is-active" : ""}>{langName[l]}</a>
            ))}
          </div>
          <button class="menu-close" id="menuClose">{t("menu.close")}</button>
        </div>
      </div>

      {/* NAV LINKS — left-aligned in right column */}
      <ul class="menu-links">
        <li class="ml-item"><a href="#top" class="ml-link" onclick="document.getElementById('menuClose').click()"><span class="ml-dot">·</span><span class="ml-text">{t("menu.home")}</span></a></li>
        <li class="ml-item"><a href="#paslaugos" class="ml-link" onclick="document.getElementById('menuClose').click()"><span class="ml-dot">·</span><span class="ml-text">{t("menu.services")}</span></a></li>
        <li class="ml-item">
          <a href="#darbai" class="ml-link" onclick="document.getElementById('menuClose').click()"><span class="ml-dot">·</span><span class="ml-text">{t("menu.portfolio")}</span></a>
          <ul class="menu-sub">
            <li><a href="#darbai" onclick="document.getElementById('menuClose').click()">{t("menu.sub.art")}</a></li>
            <li><a href="#darbai" onclick="document.getElementById('menuClose').click()">{t("menu.sub.products")}</a></li>
            <li><a href="#darbai" onclick="document.getElementById('menuClose').click()">{t("menu.sub.fashion")}</a></li>
            <li><a href="#darbai" onclick="document.getElementById('menuClose').click()">{t("menu.sub.other")}</a></li>
          </ul>
        </li>
        <li class="ml-item"><a href="#paslaugos" class="ml-link" onclick="document.getElementById('menuClose').click()"><span class="ml-dot">·</span><span class="ml-text">{t("menu.about")}</span></a></li>
        <li class="ml-item"><a href="#" class="ml-link" onclick="document.getElementById('menuClose').click()"><span class="ml-dot">·</span><span class="ml-text">{t("menu.blog")}</span></a></li>
        <li class="ml-item"><a href="#faq" class="ml-link" onclick="document.getElementById('menuClose').click()"><span class="ml-dot">·</span><span class="ml-text">{t("menu.faq")}</span></a></li>
        <li class="ml-item"><a href="#kontaktai" class="ml-link" onclick="document.getElementById('menuClose').click()"><span class="ml-dot">·</span><span class="ml-text">{t("menu.contact")}</span></a></li>
      </ul>
      <hr class="menu-nav-divider" />

      {/* BOTTOM: social left, reel right */}
      <div class="menu-foot">
        <div class="menu-foot-left">
          <a class="mf-icon" href="https://instagram.com/notreal.inga" target="_blank" rel="noopener" aria-label="Instagram">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r=".6" fill="currentColor" stroke="none"/></svg>
          </a>
          <a class="mf-icon" href="#" target="_blank" rel="noopener" aria-label="LinkedIn" data-todo="Pakeisk # į LinkedIn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="3"/><path d="M7 10v7M7 7v.01M11 17v-4a2 2 0 0 1 4 0v4M11 10v7"/></svg>
          </a>
          <a class="mf-icon" href="#" target="_blank" rel="noopener" aria-label="WhatsApp" data-todo="Pakeisk # į wa.me/+370XXXXXXXX">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5Z"/></svg>
          </a>
          <a class="mf-icon" href="#kontaktai" aria-label="Rašyk mums" onclick="document.getElementById('menuClose').click()">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m2 7 10 7 10-7"/></svg>
          </a>
        </div>
      </div>

    </div>
  </nav>

  <main id="top">
    {/* HERO */}
    <section class="hero">
      <div class="hero-media">
        {/* TIKRAS VIDEO: pakeisk placeholder bloką šituo (ir įkelk failą):
        <video autoplay muted loop playsinline poster="assets/hero-poster.jpg">
          <source src="assets/hero.mp4" type="video/mp4">
        </video> */}
        <div class="hero-ph" id="heroPh"></div>
        <div class="hero-grain"></div>
      </div>
      <div class="hero-scrim"></div>

      <div class="hero-tag">
        <div class="play" id="playReel">
          <span class="circ">▶</span><span>{t("hero.play")}</span>
        </div>
        <div class="ph-note" style="margin-top:16px">{t("hero.ph_note")}</div>
      </div>

      <div class="wrap hero-content">
        <div class="eyebrow reveal">{t("hero.eyebrow")}</div>
        <h1 class="reveal" set:html={t("hero.h1")}></h1>
        <p class="sub reveal">{t("hero.sub")}</p>
      </div>
    </section>

    {/* GIANT SERVICES */}
    <section class="giant" id="paslaugos">
      <div class="wrap">
        <div class="giant-label reveal">{t("giant.label")}</div>
        <h2 class="giant-type reveal">{t("giant.beauty")} (<a class="gtile" href="#kontaktai" aria-label={t("giant.beauty_a")}><span class="gtile-media"><span class="gph gph-1"></span></span><span class="gcue">{t("giant.cue_l")}</span></a>) {t("giant.fashion")} (<a class="gtile" href="#kontaktai" aria-label={t("giant.fashion_a")}><span class="gtile-media"><span class="gph gph-2"></span></span><span class="gcue">{t("giant.cue_r")}</span></a>) {t("giant.wellness")} (<a class="gtile" href="#kontaktai" aria-label={t("giant.wellness_a")}><span class="gtile-media"><span class="gph gph-3"></span></span><span class="gcue">{t("giant.cue_l")}</span></a>)</h2>
        <p class="giant-state reveal" set:html={t("giant.state")}></p>
      </div>
    </section>

    {/* WORK */}
    <section class="block" id="darbai">
      <div class="wrap">
        <div class="work-head">
          <div>
            <div class="kicker reveal">{t("work.kicker")}</div>
            <h2 class="statement reveal" set:html={t("work.statement")}></h2>
          </div>
          <p class="lead reveal" style="margin-top:0">{t("work.lead")}</p>
        </div>
        <div class="gal">
          {work.map((n) => (
            <article class="gal-item reveal">
              <div class="gal-media"><div class="gal-ph">{t(`work.${n}_ph`)}</div></div>
              <div class="gal-cap"><span class="gi">(0{n})</span><span class="gt">{t(`work.${n}_t`)}</span><span class="gd">{t(`work.${n}_d`)}</span></div>
              <p class="gp">{t(`work.${n}_desc`)}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    {/* FAQ */}
    <section class="block" id="faq">
      <div class="wrap">
        <div class="kicker reveal">{t("faq.kicker")}</div>
        <h2 class="statement reveal" set:html={t("faq.h2")}></h2>
        <div class="faq-list">
          {[1, 2, 3, 4, 5, 6].map((n) => (
            <details class="faq-item reveal">
              <summary>{t(`faq.${n}_q`)}</summary>
              <p>{t(`faq.${n}_a`)}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    {/* CTA */}
    <section class="block cta">
      <div class="wrap">
        <h2 class="reveal" set:html={t("cta.h2")}></h2>
        <a class="cta-btn reveal" href="#kontaktai">{t("cta.btn")}</a>
      </div>
    </section>

    {/* CONTACT */}
    <section class="block" id="kontaktai" style="border-top:1px solid var(--line)">
      <div class="wrap">
        <div class="kicker reveal">{t("contact.kicker")}</div>
        <div class="contact-shell">
          <div class="reveal">
            <h2 class="statement" set:html={t("contact.h2")}></h2>
            <p class="lead">{t("contact.lead")}</p>
            <div class="c-links">
              <a href="mailto:labas@not-real.ai">labas@not-real.ai</a>
              <a href="https://instagram.com/notreal.inga" target="_blank" rel="noopener">{t("contact.instagram")}</a>
            </div>
          </div>
          <form id="contact-form" class="reveal">
            <input type="hidden" name="access_key" value="7092e718-fa64-44a3-b8de-428b83b5391e" />
            <input type="hidden" name="subject" value={t("form.subject")} />
            <input type="hidden" name="from_name" value={t("form.from")} />
            <input type="checkbox" name="botcheck" class="hp" tabindex="-1" autocomplete="off" />
            <label for="name">{t("form.name_label")}</label>
            <input id="name" name="name" type="text" placeholder={t("form.name_ph")} required />
            <label for="email">{t("form.email_label")}</label>
            <input id="email" name="email" type="email" placeholder={t("form.email_ph")} required />
            <label for="message">{t("form.msg_label")}</label>
            <textarea id="message" name="message" placeholder={t("form.msg_ph")} required></textarea>
            <button class="cbtn" type="submit">{t("form.submit")}</button>
            <div class="form-msg" id="form-msg" role="status"></div>
          </form>
        </div>
      </div>
    </section>
  </main>

  <footer>
    <div class="wrap foot">
      <a class="brand" href="#top" style="color:var(--cream)"><span class="dot"></span>Not Real</a>
      <span class="tag">{t("footer.tag")}</span>
      <a style="color:var(--pink);font-weight:500" href="mailto:labas@not-real.ai">labas@not-real.ai</a>
    </div>
  </footer>

  {/* FLOATING SOCIAL DOCK */}
  <div class="social-dock" aria-label="Social links">
    <a class="sd-btn" href="https://instagram.com/notreal.inga" target="_blank" rel="noopener" aria-label="Instagram">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r=".6" fill="currentColor" stroke="none"/>
      </svg>
    </a>
    <a class="sd-btn" href="#" target="_blank" rel="noopener" aria-label="LinkedIn" data-todo="Pakeisk # į LinkedIn nuorodą">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <rect x="2" y="2" width="20" height="20" rx="3"/><path d="M7 10v7M7 7v.01M11 17v-4a2 2 0 0 1 4 0v4M11 10v7"/>
      </svg>
    </a>
    <a class="sd-btn" href="#" target="_blank" rel="noopener" aria-label="WhatsApp" data-todo="Pakeisk # į wa.me/+370XXXXXXXX">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5Z"/>
      </svg>
    </a>
    <a class="sd-btn" href="#kontaktai" aria-label="Rašyk mums">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <rect x="2" y="4" width="20" height="16" rx="2"/><path d="m2 7 10 7 10-7"/>
      </svg>
    </a>
  </div>
</Base>
